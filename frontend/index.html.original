<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivo Core Engine - Enterprise Delivery Platform</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ==========================================================================
           1. PREMIUM DESIGN SYSTEM & THEME
           ========================================================================== */
        :root {
            --bg: #070A13;
            --surface: rgba(13, 18, 33, 0.75);
            --surface-accent: rgba(22, 28, 45, 0.95);
            --border: rgba(255, 255, 255, 0.08);
            --primary: #FF2A54;
            --primary-rgb: 255, 42, 84;
            --primary-glow: rgba(255, 42, 84, 0.35);
            --secondary: #00F5D4;
            --secondary-glow: rgba(0, 245, 212, 0.35);
            --text-main: #F3F4F6;
            --text-muted: #9CA3AF;
            --neon-blue: #00E5FF;
            --neon-green: #39FF14;
            --neon-yellow: #FFE600;
            --neon-purple: #BD00FF;
            
            --glass-bg: rgba(13, 18, 33, 0.65);
            --glass-border: rgba(255, 255, 255, 0.06);
            --shadow-glass: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
            --radius-sm: 8px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            --font-display: 'Space Grotesk', sans-serif;
            --font-body: 'Plus Jakarta Sans', sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            outline: none;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--bg);
            color: var(--text-main);
            overflow-x: hidden;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 280px 1fr;
        }

        /* Ambient Glow background layers */
        .glow-sphere-1 {
            position: fixed;
            width: 700px;
            height: 700px;
            top: -200px;
            left: -150px;
            background: radial-gradient(circle, rgba(var(--primary-rgb), 0.09) 0%, transparent 65%);
            z-index: -2;
            pointer-events: none;
        }

        .glow-sphere-2 {
            position: fixed;
            width: 800px;
            height: 800px;
            bottom: -300px;
            right: -150px;
            background: radial-gradient(circle, rgba(0, 245, 212, 0.07) 0%, transparent 65%);
            z-index: -2;
            pointer-events: none;
        }

        /* ==========================================================================
           2. SIDEBAR PANEL
           ========================================================================== */
        aside {
            background: var(--surface-accent);
            border-right: 1px solid var(--border);
            padding: 25px 15px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: sticky;
            top: 0;
            height: 100vh;
            z-index: 100;
        }

        .aside-header {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 20px;
        }

        .aside-header i {
            font-size: 24px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 5px var(--primary-glow));
        }

        .aside-header h1 {
            font-family: var(--font-display);
            font-size: 20px;
            font-weight: 700;
        }

        .menu-scroll {
            flex-grow: 1;
            overflow-y: auto;
            margin-bottom: 20px;
        }

        .menu-scroll::-webkit-scrollbar {
            width: 4px;
        }
        .menu-scroll::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.1);
            border-radius: 2px;
        }

        .menu-group {
            margin-bottom: 20px;
        }

        .menu-title {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            margin-bottom: 10px;
            padding-left: 8px;
            font-weight: 700;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            font-size: 13.5px;
            transition: var(--transition);
            cursor: pointer;
            margin-bottom: 2px;
        }

        .menu-item:hover, .menu-item.active {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.04);
            border-left: 3px solid var(--primary);
            padding-left: 11px;
        }

        .menu-item.active i {
            color: var(--primary);
            text-shadow: 0 0 8px var(--primary-glow);
        }

        .system-status {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border);
            padding: 12px;
            border-radius: var(--radius-sm);
            font-size: 11px;
        }

        .status-indicator {
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 600;
            color: var(--neon-green);
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--neon-green);
            box-shadow: 0 0 6px var(--neon-green);
        }

        /* ==========================================================================
           3. MAIN LAYOUT AND HEADER
           ========================================================================== */
        main {
            padding: 30px;
            height: 100vh;
            overflow-y: auto;
            position: relative;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .header-title h2 {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 700;
        }

        .header-title p {
            font-size: 13px;
            color: var(--text-muted);
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .header-btn {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            color: var(--text-main);
            font-weight: 600;
            font-size: 12.5px;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .header-btn:hover {
            border-color: var(--primary);
            background: rgba(255, 56, 92, 0.05);
        }

        .badge {
            background: var(--primary);
            color: white;
            font-size: 9px;
            font-weight: 800;
            border-radius: 50%;
            width: 16px;
            height: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: 4px;
        }

        /* ==========================================================================
           4. GLOBAL VIEWS AND FORMS
           ========================================================================== */
        .app-view {
            display: none;
            animation: viewFadeIn 0.3s ease-out forwards;
        }

        .app-view.active {
            display: block;
        }

        @keyframes viewFadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }

        .card-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 24px;
            box-shadow: var(--shadow-glass);
            margin-bottom: 25px;
        }

        .card-box h4 {
            font-family: var(--font-display);
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 15px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .input-row {
            margin-bottom: 12px;
        }

        .input-row label {
            display: block;
            font-size: 11.5px;
            margin-bottom: 4px;
            color: var(--text-muted);
        }

        .input-row input, .input-row select {
            width: 100%;
            background: rgba(0,0,0,0.25);
            border: 1px solid var(--border);
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            color: var(--text-main);
            font-size: 13.5px;
            outline: none;
        }

        .input-row input:focus {
            border-color: var(--primary);
        }

        /* ==========================================================================
           5. VIEW: CUSTOMER PORTAL
           ========================================================================== */
        .shop-hero {
            background: linear-gradient(135deg, rgba(var(--primary-rgb), 0.12) 0%, transparent 60%);
            border: 1px solid var(--border);
            padding: 30px;
            border-radius: var(--radius-lg);
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            backdrop-filter: blur(10px);
        }

        .shop-hero-text h3 {
            font-family: var(--font-display);
            font-size: 28px;
            margin-bottom: 8px;
        }

        .shop-hero-text p {
            color: var(--text-muted);
            font-size: 14px;
            max-width: 480px;
            line-height: 1.4;
        }

        .search-bar {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(0,0,0,0.2);
            border: 1px solid var(--border);
            padding: 10px 16px;
            border-radius: var(--radius-sm);
            width: 380px;
            margin-top: 15px;
        }

        .search-bar input {
            background: transparent;
            border: none;
            outline: none;
            color: var(--text-main);
            font-size: 13.5px;
            width: 100%;
        }

        .search-bar i {
            color: var(--primary);
        }

        .store-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            overflow: hidden;
            transition: var(--transition);
            cursor: pointer;
            position: relative;
        }

        .store-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary);
        }

        .store-img {
            height: 160px;
            background: linear-gradient(135deg, rgba(var(--primary-rgb), 0.1), rgba(0,245,212,0.1));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            position: relative;
        }

        .store-tag {
            position: absolute;
            top: 12px;
            left: 12px;
            background: var(--primary);
            padding: 4px 10px;
            border-radius: 50px;
            font-size: 10px;
            font-weight: 700;
        }

        .favorite-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(0,0,0,0.4);
            border: 1px solid var(--border);
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            cursor: pointer;
            transition: var(--transition);
        }

        .favorite-btn.active i {
            color: #FFD253;
        }

        .store-info {
            padding: 20px;
        }

        .store-info h4 {
            font-family: var(--font-display);
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .store-info p {
            font-size: 12.5px;
            color: var(--text-muted);
            margin-bottom: 12px;
        }

        .store-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 11.5px;
            border-top: 1px solid var(--border);
            padding-top: 10px;
        }

        .store-meta span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .store-meta i {
            color: var(--primary);
        }

        /* Menu details */
        .menu-item-row {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 16px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: var(--transition);
        }

        .menu-item-row:hover {
            border-color: var(--primary);
        }

        .menu-item-desc h5 {
            font-family: var(--font-display);
            font-size: 15px;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .menu-item-desc p {
            font-size: 12px;
            color: var(--text-muted);
            max-width: 580px;
        }

        .menu-item-action {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .menu-price {
            font-family: var(--font-display);
            font-size: 15px;
            font-weight: 700;
            color: var(--primary);
        }

        .action-add-btn {
            background: var(--primary);
            border: none;
            color: white;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
        }

        .action-add-btn:hover {
            transform: scale(1.08);
        }

        /* Split bill & loyalty widgets */
        .utility-box {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 30px;
        }

        /* In-App Support Chat Box */
        .support-chat-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            height: 250px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow: hidden;
        }

        .chat-messages {
            flex-grow: 1;
            overflow-y: auto;
            padding: 15px;
            font-size: 12px;
        }

        .chat-bubble {
            margin-bottom: 10px;
            padding: 8px 12px;
            border-radius: 12px;
            max-width: 80%;
        }

        .chat-bubble.bot {
            background: rgba(255,255,255,0.06);
            align-self: flex-start;
        }

        .chat-bubble.user {
            background: var(--primary);
            color: white;
            align-self: flex-end;
            margin-left: auto;
        }

        .chat-input-area {
            border-top: 1px solid var(--border);
            display: flex;
            background: rgba(0,0,0,0.2);
        }

        .chat-input-area input {
            flex-grow: 1;
            background: transparent;
            border: none;
            padding: 10px 15px;
            color: var(--text-main);
            font-size: 12px;
        }

        .chat-send-btn {
            background: var(--primary);
            border: none;
            color: white;
            padding: 0 15px;
            cursor: pointer;
        }

        /* ==========================================================================
           6. VIEW: REAL-TIME TRACKING
           ========================================================================== */
        .track-grid {
            display: grid;
            grid-template-columns: 0.9fr 1.1fr;
            gap: 25px;
        }

        .saga-timeline-wrapper {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 25px;
        }

        .saga-timeline {
            position: relative;
            padding-left: 25px;
            margin-top: 25px;
        }

        .saga-timeline::before {
            content: '';
            position: absolute;
            top: 5px;
            left: 5px;
            width: 2px;
            height: calc(100% - 10px);
            background: rgba(255,255,255,0.1);
        }

        .saga-timeline-fill {
            position: absolute;
            top: 5px;
            left: 5px;
            width: 2px;
            height: 0%;
            background: var(--primary);
            transition: height 2s ease;
        }

        .saga-node {
            position: relative;
            margin-bottom: 30px;
        }

        .saga-dot {
            position: absolute;
            left: -25px;
            top: 3px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--border);
            border: 2px solid var(--bg);
        }

        .saga-node.active .saga-dot {
            background: var(--primary);
            box-shadow: 0 0 8px var(--primary);
        }

        .saga-node.completed .saga-dot {
            background: var(--neon-green);
            box-shadow: 0 0 8px var(--neon-green);
        }

        .saga-node-text h6 {
            font-family: var(--font-display);
            font-size: 14.5px;
            font-weight: 700;
        }

        .saga-node-text p {
            font-size: 11.5px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .svg-map-wrapper {
            background: #0D1221;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            overflow: hidden;
            position: relative;
            height: 400px;
        }

        .svg-canvas {
            width: 100%;
            height: 100%;
        }

        /* ==========================================================================
           7. VIEW: MERCHANT PORTAL
           ========================================================================== */
        .kanban-board {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 20px;
        }

        .kanban-col {
            background: rgba(0,0,0,0.25);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 15px;
            min-height: 380px;
        }

        .kanban-col h4 {
            font-family: var(--font-display);
            font-size: 14px;
            border-bottom: 2px solid var(--border);
            padding-bottom: 8px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
        }

        .kanban-card {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 12px;
            border-radius: var(--radius-sm);
            margin-bottom: 10px;
            cursor: grab;
            transition: var(--transition);
        }

        .kanban-card:hover {
            border-color: var(--primary);
        }

        .kanban-card h5 {
            font-size: 12px;
            font-weight: 700;
        }

        .kanban-card p {
            font-size: 10px;
            color: var(--text-muted);
            margin-top: 4px;
        }

        .kanban-card-actions {
            margin-top: 8px;
            display: flex;
            justify-content: flex-end;
        }

        .kanban-card-btn {
            background: var(--primary);
            border: none;
            color: white;
            font-size: 9px;
            padding: 3px 6px;
            border-radius: 4px;
            cursor: pointer;
        }

        .menu-crud-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            background: var(--surface);
            border-radius: var(--radius-sm);
            overflow: hidden;
            font-size: 13px;
        }

        .menu-crud-table th, .menu-crud-table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        .menu-crud-table th {
            font-family: var(--font-display);
            font-weight: 700;
            background: rgba(255,255,255,0.02);
        }

        .menu-crud-table tr:hover {
            background: rgba(255,255,255,0.01);
        }

        /* ==========================================================================
           8. VIEW: DRIVER DASHBOARD
           ========================================================================== */
        .driver-dashboard {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }

        .earnings-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 24px;
            text-align: center;
        }

        .earnings-total {
            font-family: var(--font-display);
            font-size: 40px;
            font-weight: 800;
            color: var(--secondary);
            margin: 12px 0;
        }

        /* ==========================================================================
           9. VIEW: ADMIN CONTROL PANEL
           ========================================================================== */
        .admin-kpi-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 25px;
        }

        .admin-kpi-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 15px;
            text-align: center;
            font-size: 13px;
        }

        .admin-kpi-num {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 700;
            color: var(--neon-blue);
            margin-top: 6px;
        }

        /* ==========================================================================
           10. VIEW: OBSERVABILITY CONSOLE
           ========================================================================== */
        .telemetry-layout {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 20px;
        }

        .log-terminal {
            background: #040710;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-family: 'Space Grotesk', monospace;
            padding: 15px;
            height: 480px;
            overflow-y: auto;
            color: #39FF14;
            font-size: 10px;
            line-height: 1.3;
        }

        .log-line {
            margin-bottom: 6px;
            white-space: pre-wrap;
        }

        .trace-visualizer {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 20px;
        }

        .trace-bar {
            height: 22px;
            border-radius: 4px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            padding-left: 8px;
            font-size: 10px;
            font-weight: 700;
            color: white;
        }

        /* ==========================================================================
           11. INTERACTIVE BACKDROP & CART SLIDE
           ========================================================================== */
        .cart-slide {
            position: fixed;
            top: 0;
            right: -400px;
            width: 400px;
            height: 100vh;
            background: var(--surface-accent);
            border-left: 1px solid var(--border);
            box-shadow: var(--shadow-glass);
            z-index: 500;
            padding: 25px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: right 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .cart-slide.open {
            right: 0;
        }

        .backdrop-tint {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(4px);
            z-index: 400;
            display: none;
        }

        .backdrop-tint.open {
            display: block;
        }
    </style>
</head>
<body>
    <!-- Radial ambient layers -->
    <div class="glow-sphere-1"></div>
    <div class="glow-sphere-2"></div>

    <!-- Side Navigation -->
    <aside>
        <div>
            <div class="aside-header">
                <i class="fa-solid fa-pizza-slice"></i>
                <h1 id="app-logo-text">Delivo Super App</h1>
            </div>
            
            <div class="menu-scroll">
                <div class="menu-group">
                    <div class="menu-title">Consumer Apps</div>
                    <div class="menu-item active" onclick="switchView('view-customer', this)">
                        <i class="fa-solid fa-bag-shopping"></i> Customer Store
                    </div>
                    <div class="menu-item" onclick="switchView('view-tracking', this)">
                        <i class="fa-solid fa-map-location-dot"></i> Real-time Tracker
                    </div>
                </div>

                <div class="menu-group">
                    <div class="menu-title">Merchant Services</div>
                    <div class="menu-item" onclick="switchView('view-restaurant', this)">
                        <i class="fa-solid fa-store"></i> Restaurant Board
                    </div>
                </div>

                <div class="menu-group">
                    <div class="menu-title">Fleet Logistics</div>
                    <div class="menu-item" onclick="switchView('view-driver', this)">
                        <i class="fa-solid fa-motorcycle"></i> Driver Dashboard
                    </div>
                </div>

                <div class="menu-group">
                    <div class="menu-title">Control & Metrics</div>
                    <div class="menu-item" onclick="switchView('view-admin', this)">
                        <i class="fa-solid fa-sliders"></i> Admin Control Center
                    </div>
                    <div class="menu-item" onclick="switchView('view-observability', this)">
                        <i class="fa-solid fa-chart-line"></i> Observability Console
                    </div>
                </div>
            </div>
        </div>

        <div class="system-status">
            <div class="status-indicator">
                <div class="status-dot"></div> System Operational
            </div>
            <div style="opacity: 0.6; margin-top: 4px; font-size: 10px;" id="region-status-text">Active Region: Multicloud active</div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main>
        <!-- Dynamic Header -->
        <header>
            <div class="header-title">
                <h2 id="view-title">Food Bounded Context Store</h2>
                <p id="view-subtitle">Select catalog items matched via Elasticsearch queries</p>
            </div>
            <div class="header-actions">
                <button class="header-btn" onclick="toggleLanguage()" id="lang-toggle-btn">
                    <i class="fa-solid fa-language"></i> EN
                </button>
                <button class="header-btn cart-indicator" onclick="openCartSlide()">
                    <i class="fa-solid fa-cart-shopping"></i> Cart
                    <div class="badge" id="cart-item-count">0</div>
                </button>
            </div>
        </header>

        <!-- ==========================================================================
           VIEW: CUSTOMER STORE
           ========================================================================== */ -->
        <div id="view-customer" class="app-view active">
            <div class="shop-hero">
                <div class="shop-hero-text">
                    <h3 id="hero-heading">Master Chef Specialties</h3>
                    <p id="hero-subheading">Orchestrate transactions with under 2-second latency budget targets across global deployment regions.</p>
                    
                    <div style="display: flex; gap: 10px; align-items: center; margin-top: 15px;">
                        <div class="search-bar">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <input type="text" id="search-bar-input" placeholder="Search menu items (Elasticsearch auto-suggester)..." oninput="triggerSearch(this.value)">
                        </div>
                        <!-- Voice Search Button -->
                        <button class="header-btn" style="height: 44px; margin-top: 15px;" onclick="startVoiceSearch()" title="Voice Search">
                            <i class="fa-solid fa-microphone" id="voice-search-icon"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Recently Viewed & Favorites widgets -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px;">
                <div class="card-box" style="margin-bottom: 0;">
                    <h4 id="fav-box-title">My Favorites & Wishlist</h4>
                    <div id="favorites-tray" style="font-size: 13px; color: var(--text-muted);">No favorites selected yet. Star a restaurant below!</div>
                </div>
                <div class="card-box" style="margin-bottom: 0;">
                    <h4 id="rec-box-title">Recently Viewed</h4>
                    <div id="recently-viewed-tray" style="font-size: 13px; color: var(--text-muted);">No stores viewed recently.</div>
                </div>
            </div>

            <div class="grid-3" id="catalog-grid">
                <!-- Render stores -->
            </div>

            <div id="restaurant-menu-details" style="display: none; margin-top: 30px;">
                <div class="menu-header-bar">
                    <h3 id="selected-restaurant-name" style="font-family: var(--font-display); font-size: 22px;">Restaurant Menu</h3>
                    <button class="header-btn" onclick="showCatalog()"><i class="fa-solid fa-chevron-left"></i> Back to Restaurants</button>
                </div>
                <div id="menu-items-list">
                    <!-- Render menu items -->
                </div>
            </div>

            <!-- AI recommendations, loyalty, and split bill utilities -->
            <div class="utility-box">
                <div class="card-box">
                    <h4>AI Meal Recommendations</h4>
                    <div id="ai-rec-text" style="font-size: 13px; line-height: 1.4;">
                        <i class="fa-solid fa-wand-magic-sparkles" style="color: var(--secondary);"></i> 
                        Recommended: <strong style="color: var(--primary);">Spicy Diavola Pizza</strong> based on your interest in Pizza and current evening hour.
                    </div>
                </div>
                <div class="card-box">
                    <h4>Loyalty Points & Referral System</h4>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <div style="font-size: 12px; color: var(--text-muted);">Loyalty Balance</div>
                            <div style="font-size: 24px; font-weight: 700; color: var(--secondary);" id="loyalty-points-val">450 Points</div>
                        </div>
                        <button class="header-btn" onclick="generateReferral()">Get Referral Link</button>
                    </div>
                </div>
            </div>

            <div class="utility-box">
                <div class="card-box">
                    <h4>Split Bill Calculator</h4>
                    <div class="input-row">
                        <label>Number of members</label>
                        <input type="number" id="split-bill-members" value="3" min="1" oninput="calculateBillSplit()">
                    </div>
                    <div style="font-size: 13px;">Split per member: <strong style="color: var(--neon-blue);" id="split-bill-amount">$0.00</strong></div>
                </div>
                
                <div class="card-box">
                    <h4>In-App Automated Support</h4>
                    <div class="support-chat-box">
                        <div class="chat-messages" id="support-chat-msg-area">
                            <div class="chat-bubble bot">Hello! How can I assist you with your order saga details today?</div>
                        </div>
                        <div class="chat-input-area">
                            <input type="text" id="chat-user-input" placeholder="Type support query...">
                            <button class="chat-send-btn" onclick="sendChatMessage()">Send</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ==========================================================================
           VIEW: CHECKOUT FORM
           ========================================================================== */ -->
        <div id="view-checkout" class="app-view">
            <div class="checkout-container">
                <div class="checkout-box">
                    <h4>Address Validation & Geofence Verification</h4>
                    <div class="input-row">
                        <label>Delivery Address</label>
                        <input type="text" id="delivery-address-field" value="123 Main St, New York, NY 10001 (Inside Active Geofence Region)">
                    </div>
                    <div class="input-row">
                        <label>Delivery Type</label>
                        <select id="delivery-type-select">
                            <option value="INSTANT">Instant Delivery (Military Speed)</option>
                            <option value="SCHEDULED">Scheduled Delivery (Surge avoidance)</option>
                        </select>
                    </div>
                    <div class="input-row">
                        <label>Contactless Delivery</label>
                        <select id="contactless-delivery-select">
                            <option value="YES">Yes, drop at my doorstep</option>
                            <option value="NO">No, hand order to me directly</option>
                        </select>
                    </div>
                    <div class="input-row">
                        <label>Payment Method Selection</label>
                        <select id="payment-method-select">
                            <option value="CARD">Credit/Debit Card (PCI-Compliant Storage)</option>
                            <option value="WALLET">Delivo Core System Wallet</option>
                            <option value="UPI">UPI Payment (Razorpay Gateway Integration)</option>
                        </select>
                    </div>
                    <div class="input-row">
                        <label>Apply Coupon Code (Try: PROMO10)</label>
                        <input type="text" id="promo-code-field" placeholder="Enter coupon code..." oninput="checkCoupon(this.value)">
                        <div id="promo-status" style="font-size: 11px; margin-top: 5px; color: var(--neon-green);"></div>
                    </div>
                </div>
                <div class="checkout-box">
                    <h4>Order Value Ledger</h4>
                    <div id="checkout-summary-items"></div>
                    <div class="checkout-total-bar">
                        <span>Grand Total</span>
                        <span id="checkout-grand-total">$0.00</span>
                    </div>
                    <button class="btn-submit-order" onclick="dispatchOrderSaga()">Confirm Order & Start Saga</button>
                </div>
            </div>
        </div>

        <!-- ==========================================================================
           VIEW: REAL-TIME TRACKER
           ========================================================================== */ -->
        <div id="view-tracking" class="app-view">
            <div class="track-grid">
                <div class="saga-timeline-wrapper">
                    <h3 id="tracking-eta" style="font-family: var(--font-display); font-size: 32px; color: var(--primary);">12 Mins Remaining</h3>
                    <p style="font-size: 12px; color: var(--text-muted);">Saga transaction id: <span id="saga-transaction-id" style="color: var(--text-main);"></span></p>
                    
                    <div class="saga-timeline">
                        <div class="saga-timeline-fill" id="saga-timeline-fill-bar"></div>
                        <div class="saga-node active" id="saga-node-placed">
                            <div class="saga-dot"></div>
                            <div class="saga-node-text">
                                <h6>Order Placed & Validated</h6>
                                <p>Saga orchestrator verified account credit ledger limits</p>
                            </div>
                        </div>
                        <div class="saga-node" id="saga-node-preparing">
                            <div class="saga-dot"></div>
                            <div class="saga-node-text">
                                <h6>Chef Approved & Preparing</h6>
                                <p>Restaurant service confirmed ingredient-level stock reservations</p>
                            </div>
                        </div>
                        <div class="saga-node" id="saga-node-delivering">
                            <div class="saga-dot"></div>
                            <div class="saga-node-text">
                                <h6>Driver Dispatched & En Route</h6>
                                <p>Logistics matches coordinates using Redis geospatial indexing</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="svg-map-wrapper">
                    <svg class="svg-canvas" viewBox="0 0 600 450" id="tracking-map-svg">
                        <!-- Grid lines -->
                        <path d="M 50 50 L 550 50 M 50 150 L 550 150 M 50 250 L 550 250 M 50 350 L 550 350 M 150 50 L 150 400 M 300 50 L 300 400 M 450 50 L 450 400" stroke="rgba(255,255,255,0.04)" stroke-width="4" fill="none"/>
                        <!-- Route path -->
                        <path id="route-polyline" d="M 300 150 L 300 350 L 150 350" stroke="var(--primary)" stroke-width="3" stroke-dasharray="6" fill="none" opacity="0.3"/>
                        <!-- Target pins -->
                        <circle cx="300" cy="150" r="8" fill="var(--secondary)" stroke="white" stroke-width="2"/>
                        <circle cx="150" cy="350" r="8" fill="white" stroke="var(--primary)" stroke-width="2"/>
                        <!-- Active Driver -->
                        <circle id="map-driver-pin" cx="300" cy="150" r="10" fill="var(--primary)" stroke="white" stroke-width="2" opacity="0"/>
                    </svg>
                </div>
            </div>
        </div>

        <!-- ==========================================================================
           VIEW: RESTAURANT PORTAL
           ========================================================================== */ -->
        <div id="view-restaurant" class="app-view">
            <!-- Dynamic Pricing & Surge Pricing toggles -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                <div class="card-box" style="margin-bottom: 0;">
                    <h4>Dynamic Surge Pricing Controller</h4>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <div style="font-size: 12px; color: var(--text-muted);">Current Pricing Multiplier</div>
