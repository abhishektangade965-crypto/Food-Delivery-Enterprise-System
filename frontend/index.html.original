                            <td><span style="color: var(--neon-green);"><i class="fa-solid fa-circle-check"></i> Stock Optimal</span></td>
                        </tr>
                        <tr>
                            <td>Mozzarella Cheese Blocks</td>
                            <td>4 Blocks</td>
                            <td>5 Blocks</td>
                            <td><span style="color: var(--primary);"><i class="fa-solid fa-triangle-exclamation"></i> Low Stock Alert</span></td>
                        </tr>
                    </tbody>
                </table>
