            <button class="cart-checkout-btn" onclick="goToCheckout()">Proceed to Billing</button>
        </div>
    </div>

    <!-- ==========================================================================
       12. CORE JS LOGIC & EVENT STREAM GENERATOR
       ========================================================================== */ -->
    <script>
        // Store and Catalog Data
        const mockStores = [
            { id: "d290f1d6-53b7-4c0a-ae8d-ec44a864cfd8", name: "Bella Napoli Pizza", cuisine: "Pizza & Italian", rating: "4.9", time: "15 min", desc: "Sourdough pizza baked at 500 degrees, using D.O.P. ingredients." },
            { id: "a897b2c6-d98c-4a30-84a6-7fdebc3992df", name: "GBK Gourmet Burger", cuisine: "Burgers & Fast Food", rating: "4.8", time: "20 min", desc: "Gourmet smash burgers with aged beef cheese and premium cuts." },
            { id: "3c98b2df-12bc-443e-a10c-f3bc30df29cb", name: "Sake Sushi House", cuisine: "Asian & Sushi", rating: "4.7", time: "25 min", desc: "Fresh sashimis, temakis, and nigiris sliced fresh daily." }
        ];

        const mockMenus = {
            "d290f1d6-53b7-4c0a-ae8d-ec44a864cfd8": [
                { id: "m1", name: "Sourdough Margherita", price: 15.99, desc: "San Marzano sauce, fresh mozzarella, organic basil, olive oil." },
                { id: "m2", name: "Calabrian Spicy Diavola", price: 17.99, desc: "Spicy salame, chili flakes, honey glaze." }
            ],
            "a897b2c6-d98c-4a30-84a6-7fdebc3992df": [
                { id: "m3", name: "Double Smash Cheese", price: 13.99, desc: "Double Angus beef, cheddar cheese, burger sauce." },
                { id: "m4", name: "Truffle Fries", price: 5.99, desc: "Crispy skin-on fries, black truffle seasoning." }
            ],
            "3c98b2df-12bc-443e-a10c-f3bc30df29cb": [
                { id: "m5", name: "Salmon Sashimi Platter", price: 21.99, desc: "12 slices of fresh Atlantic salmon sashimi." },
                { id: "m6", name: "Crispy Prawn Tempura", price: 12.99, desc: "Lightly battered tempura prawns with sweet chili dip." }
            ]
        };

        // App States
        let cartItems = [];
        let activeCuisineFilter = 'All';
        let currentOpenRestaurant = null;
        let selectedPayment = 'CARD';
        let appliedDiscount = 0;
        let activeOrderSaga = null;
        let currentLang = 'EN';
        let favorites = [];
        let recentlyViewed = [];

        // Dynamic multi-language dictionary
        const translationDict = {
            'EN': {
                'title': 'Food Bounded Context Store',
                'sub': 'Select catalog items matched via Elasticsearch queries',
                'hero-h': 'Master Chef Specialties',
                'hero-sub': 'Orchestrate transactions with under 2-second latency budget targets across global deployment regions.',
                'fav-t': 'My Favorites & Wishlist',
                'rec-t': 'Recently Viewed'
            },
            'HI': {
                'title': 'खाद्य सीमाबद्ध संदर्भ स्टोर',
                'sub': 'इलास्टिकसर्च प्रश्नों के माध्यम से मिलान किए गए कैटलॉग आइटम चुनें',
                'hero-h': 'मास्टर शेफ विशेषताएँ',
                'hero-sub': 'वैश्विक परिनियोजन क्षेत्रों में 2-सेकंड से कम विलंबता बजट लक्ष्यों के साथ लेनदेन का आयोजन करें।',
                'fav-t': 'मेरी पसंदीदा और इच्छासूची',
                'rec-t': 'हाल ही में देखा गया'
            },
            'ES': {
                'title': 'Tienda de Contexto de Alimentos',
                'sub': 'Seleccione artículos del catálogo emparejados mediante consultas de Elasticsearch',
                'hero-h': 'Especialidades de Master Chef',
                'hero-sub': 'Orqueste transacciones con objetivos de presupuesto de latencia de menos de 2 segundos en regiones globales.',
                'fav-t': 'Mis Favoritos',
                'rec-t': 'Visto Recientemente'
            }
        };

        // Toggle Language
        function toggleLanguage() {
            const langs = ['EN', 'HI', 'ES'];
            let nextIdx = (langs.indexOf(currentLang) + 1) % langs.length;
            currentLang = langs[nextIdx];
            document.getElementById('lang-toggle-btn').innerHTML = `<i class="fa-solid fa-language"></i> ${currentLang}`;
            
            const t = translationDict[currentLang];
            document.getElementById('view-title').innerText = t['title'];
            document.getElementById('view-subtitle').innerText = t['sub'];
            document.getElementById('hero-heading').innerText = t['hero-h'];
            document.getElementById('hero-subheading').innerText = t['hero-sub'];
            document.getElementById('fav-box-title').innerText = t['fav-t'];
            document.getElementById('rec-box-title').innerText = t['rec-t'];
        }

        // Voice Search (Speech Recognition)
        function startVoiceSearch() {
            const mic = document.getElementById('voice-search-icon');
            const input = document.getElementById('search-bar-input');
            
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SpeechRecognition) {
                alert("Voice recognition is not supported on this browser version.");
                return;
            }
            
            const recognition = new SpeechRecognition();
            recognition.lang = 'en-US';
            
            mic.style.color = '#39FF14'; // turn green during recording
            recognition.start();
            
            recognition.onresult = function(event) {
                const speechResult = event.results[0][0].transcript;
                input.value = speechResult;
                triggerSearch(speechResult);
                mic.style.color = 'var(--primary)';
            };

            recognition.onerror = function() {
                mic.style.color = 'var(--primary)';
            };
        }

        // In-App Chat Simulation
        function sendChatMessage() {
            const input = document.getElementById('chat-user-input');
            const msg = input.value.trim();
            if (!msg) return;
            
            const chatArea = document.getElementById('support-chat-msg-area');
            chatArea.innerHTML += `<div class="chat-bubble user">${msg}</div>`;
            input.value = '';
            
            setTimeout(() => {
                let botReply = "I have queried the CDC outbox event logs. Your saga state is completely consistent.";
                if (msg.toLowerCase().includes('refund')) {
                    botReply = "Refund initiated successfully under saga compensation rules. Fund settlement complete.";
                }
                chatArea.innerHTML += `<div class="chat-bubble bot">${botReply}</div>`;
                chatArea.scrollTop = chatArea.scrollHeight;
            }, 1000);
        }

        // View Navigator
        function switchView(viewId, element) {
            document.querySelectorAll('.app-view').forEach(view => {
                view.classList.remove('active');
            });
            document.getElementById(viewId).classList.add('active');

            if (element) {
                document.querySelectorAll('.menu-item').forEach(item => {
                    item.classList.remove('active');
                });
                element.classList.add('active');
            }

            // Sync Header Titles
            const titleMap = {
                'view-customer': ['Food Bounded Context Store', 'Select catalog items matched via Elasticsearch queries'],
                'view-checkout': ['Billing & Address Validation', 'Finalize transaction ledger limits'],
                'view-tracking': ['Real-Time Tracking Orchestrator', 'Monitor Saga workflow lifecycle state events'],
                'view-restaurant': ['Restaurant Kanban Desk', 'Manage order queues and inventory states'],
                'view-driver': ['Fleet Logistics Board', 'Monitor active route deliveries and payouts'],
                'view-admin': ['System Operations Dashboard', 'Global telemetry metrics and fraud thresholds'],
                'view-observability': ['Observability Console Feed', 'Distributed sleuth JSON tracing logs']
            };

            const headerInfo = titleMap[viewId];
            if (headerInfo) {
                document.getElementById('view-title').innerText = headerInfo[0];
                document.getElementById('view-subtitle').innerText = headerInfo[1];
            }
        }

        // Toggle Favorites
        function toggleFavorite(storeId, event) {
            event.stopPropagation();
            const btn = document.getElementById(`fav-btn-${storeId}`);
            const index = favorites.indexOf(storeId);
            
            if (index > -1) {
                favorites.splice(index, 1);
                btn.classList.remove('active');
            } else {
                favorites.push(storeId);
                btn.classList.add('active');
            }
            updateFavoritesTray();
        }

        function updateFavoritesTray() {
            const tray = document.getElementById('favorites-tray');
            if (favorites.length === 0) {
                tray.innerText = "No favorites selected yet. Star a restaurant below!";
                return;
            }
            const favNames = favorites.map(fId => mockStores.find(s => s.id === fId).name);
            tray.innerHTML = favNames.map(name => `<span class="store-tag" style="position:relative; margin-right: 5px;">${name}</span>`).join(' ');
        }

        // Dynamic Pricing Surge
        function toggleSurge(val) {
            const rate = parseFloat(val);
            const surgeVal = document.getElementById('surge-multiplier-val');
            if (rate > 1.0) {
                surgeVal.innerText = `${rate}x (Surge Active)`;
                surgeVal.style.color = 'var(--primary)';
            } else {
                surgeVal.innerText = "1.0x (Normal)";
                surgeVal.style.color = 'var(--secondary)';
            }
            // Recalculate bill with surge pricing
            updateCartCounter();
        }

        // Cart Actions
        function openCartSlide() {
            document.getElementById('cart-slideout').classList.add('open');
            document.querySelector('.backdrop-tint').classList.add('open');
        }

        function toggleCartSlide() {
            document.getElementById('cart-slideout').classList.remove('open');
            document.querySelector('.backdrop-tint').classList.remove('open');
        }

        function addToCart(itemId, storeId) {
            const item = mockMenus[storeId].find(i => i.id === itemId);
            if (!item) return;

            const existing = cartItems.find(c => c.id === itemId);
            if (existing) {
                existing.qty++;
            } else {
                cartItems.push({ ...item, qty: 1, storeId });
            }
            updateCartCounter();
            addLog("cart-service", `Added item ${item.name} to cart. Status: Active`);
        }

        function updateCartCounter() {
            const count = cartItems.reduce((acc, curr) => acc + curr.qty, 0);
            document.getElementById('cart-item-count').innerText = count;

            const subtotal = cartItems.reduce((acc, curr) => acc + (curr.price * curr.qty), 0);
            
            // Apply surge multiplier if active
            const surgeVal = parseFloat(document.getElementById('surge-toggle').value);
            const pricedSubtotal = subtotal * surgeVal;

            document.getElementById('cart-slide-subtotal').innerText = `$${pricedSubtotal.toFixed(2)}`;
            document.getElementById('checkout-grand-total').innerText = `$${(pricedSubtotal - (pricedSubtotal * appliedDiscount)).toFixed(2)}`;
            
            calculateBillSplit();
        }

        function calculateBillSplit() {
            const subtotal = cartItems.reduce((acc, curr) => acc + (curr.price * curr.qty), 0);
            const members = parseInt(document.getElementById('split-bill-members').value) || 1;
            const split = subtotal / members;
            document.getElementById('split-bill-amount').innerText = `$${split.toFixed(2)}`;
        }

        function goToCheckout() {
            toggleCartSlide();
            
            const summary = document.getElementById('checkout-summary-items');
            summary.innerHTML = '';
            cartItems.forEach(item => {
                summary.innerHTML += `
                    <div class="summary-item">
                        <span>${item.qty}x ${item.name}</span>
                        <span>$${(item.price * item.qty).toFixed(2)}</span>
                    </div>
                `;
            });
            switchView('view-checkout');
        }

        function checkCoupon(code) {
            const status = document.getElementById('promo-status');
            if (code === 'PROMO10') {
                appliedDiscount = 0.10;
                status.innerText = "Coupon PROMO10 applied: 10% Discount active!";
            } else {
                appliedDiscount = 0;
                status.innerText = "";
            }
            updateCartCounter();
        }

        // Place Order - Start Saga Workflow
        function dispatchOrderSaga() {
            if (cartItems.length === 0) {
                alert("Your cart is empty!");
                return;
            }

            const transactionId = "tx_" + Math.random().toString(36).substr(2, 9);
            document.getElementById('saga-transaction-id').innerText = transactionId;
            switchView('view-tracking');

            // Initialize Progress
            const fill = document.getElementById('saga-timeline-fill-bar');
            fill.style.height = '0%';
            document.getElementById('saga-node-placed').className = 'saga-node active';
            document.getElementById('saga-node-preparing').className = 'saga-node';
            document.getElementById('saga-node-delivering').className = 'saga-node';

            // Add Order to Restaurant Kanban
            addOrderToKanban(transactionId);

            addLog("order-service", `Order creation saga initiated. Transaction ID: ${transactionId}`);
            
            // Step 1 -> Step 2
            setTimeout(() => {
                document.getElementById('saga-node-placed').className = 'saga-node completed';
                document.getElementById('saga-node-preparing').className = 'saga-node active';
                fill.style.height = '50%';
                addLog("payment-service", `Payment validation successful. Wallet balance debited.`);
                addLog("restaurant-service", `Chef approved order ${transactionId}. Initiating ingredient reservation.`);
            }, 3000);
        }

        // Kanban Order Sync
        function addOrderToKanban(txId) {
            const container = document.getElementById('kanban-pending-list');
            const itemsSummary = cartItems.map(c => `${c.qty}x ${c.name}`).join(', ');
            
            container.innerHTML += `
                <div class="kanban-card" id="k-card-${txId}">
                    <h5>Order Reference: ${txId}</h5>
                    <p>Items: ${itemsSummary}</p>
                    <div class="kanban-card-actions">
                        <button class="kanban-card-btn" onclick="advanceKanban('${txId}')">Advance Status</button>
                    </div>
                </div>
            `;
            updateKanbanCounters();
        }

        function advanceKanban(txId) {
            const card = document.getElementById(`k-card-${txId}`);
            if (!card) return;

            const currentParent = card.parentElement.id;
            if (currentParent === 'kanban-pending-list') {
                document.getElementById('kanban-prep-list').appendChild(card);
                addLog("restaurant-service", `Order ${txId} state advanced to: PREPARING`);
            } else if (currentParent === 'kanban-prep-list') {
                document.getElementById('kanban-done-list').appendChild(card);
                addLog("delivery-service", `Order ${txId} dispatched. Driver geohash matching active.`);
                
                // Trigger delivery driver map movement
                triggerDriverMovement(txId);
            }
            updateKanbanCounters();
        }

        function updateKanbanCounters() {
            document.getElementById('count-pending').innerText = document.getElementById('kanban-pending-list').children.length;
            document.getElementById('count-prep').innerText = document.getElementById('kanban-prep-list').children.length;
            document.getElementById('count-done').innerText = document.getElementById('kanban-done-list').children.length;
        }

        // Driver map navigation animation
        function triggerDriverMovement(txId) {
            switchView('view-tracking');
            const fill = document.getElementById('saga-timeline-fill-bar');
            document.getElementById('saga-node-preparing').className = 'saga-node completed';
            document.getElementById('saga-node-delivering').className = 'saga-node active';
            fill.style.height = '100%';

            const driverPin = document.getElementById('map-driver-pin');
            const route = document.getElementById('route-polyline');
            driverPin.setAttribute('opacity', '1');
            route.setAttribute('opacity', '1');

            let steps = 0;
            const points = [
                {x: 300, y: 150}, {x: 300, y: 200}, {x: 300, y: 250},
                {x: 300, y: 300}, {x: 300, y: 350}, {x: 250, y: 350},
                {x: 200, y: 350}, {x: 150, y: 350}
            ];

            const interval = setInterval(() => {
                if (steps >= points.length) {
                    clearInterval(interval);
                    document.getElementById('tracking-eta').innerText = "Order Delivered!";
                    document.getElementById('saga-node-delivering').className = 'saga-node completed';
                    addLog("delivery-service", `Order ${txId} marked as DELIVERED by fleet driver.`);
                    
                    // Add earnings to driver wallet
                    addDriverEarnings();
                    return;
                }
                const pt = points[steps];
                driverPin.setAttribute('cx', pt.x);
                driverPin.setAttribute('cy', pt.y);
                
                const lat = (40.7128 - (steps * 0.001)).toFixed(4);
                const lon = (-74.0060 + (steps * 0.001)).toFixed(4);
                document.getElementById('coordinates-log').innerText = `${lat}° N, ${lon}° W`;

                steps++;
            }, 1000);
        }

        // Payout transfer
        function addDriverEarnings() {
            const currentBalance = parseFloat(document.getElementById('driver-wallet-balance').innerText.replace('$', ''));
            const newBalance = currentBalance + 15.75;
            document.getElementById('driver-wallet-balance').innerText = `$${newBalance.toFixed(2)}`;
        }

        function requestPayout() {
            alert("Payout processing successful. Funds transferred to target bank account registry.");
            document.getElementById('driver-wallet-balance').innerText = "$0.00";
        }

        // Search & Elasticsearch matching simulation
        function triggerSearch(query) {
            const catalog = document.getElementById('catalog-grid');
            if (!query) {
                renderCatalog(mockStores);
                return;
            }

            const filtered = mockStores.filter(s => 
                s.name.toLowerCase().includes(query.toLowerCase()) || 
                s.cuisine.toLowerCase().includes(query.toLowerCase())
            );
            renderCatalog(filtered);
            addLog("search-service", `Elasticsearch query executed: "${query}" - Matches found: ${filtered.length}`);
        }

        // Render catalog stores
        function renderCatalog(stores) {
            const container = document.getElementById('catalog-grid');
            container.innerHTML = '';
            stores.forEach(s => {
                container.innerHTML += `
                    <div class="store-card" onclick="openMenu('${s.id}')">
                        <div class="store-img">
                            <i class="fa-solid fa-store"></i>
                            <div class="store-tag">${s.cuisine}</div>
                            <button class="favorite-btn" id="fav-btn-${s.id}" onclick="toggleFavorite('${s.id}', event)">
                                <i class="fa-solid fa-star"></i>
                            </button>
                        </div>
                        <div class="store-info">
                            <h4>${s.name}</h4>
                            <p>${s.desc}</p>
                            <div class="store-meta">
                                <span><i class="fa-solid fa-star"></i> ${s.rating}</span>
                                <span><i class="fa-solid fa-clock"></i> ${s.time}</span>
                            </div>
                        </div>
                    </div>
                `;
            });
        }

        function openMenu(storeId) {
            const store = mockStores.find(s => s.id === storeId);
            if (!store) return;

            document.getElementById('catalog-grid').style.display = 'none';
            document.getElementById('restaurant-menu-details').style.display = 'block';
            document.getElementById('selected-restaurant-name').innerText = store.name;

            const list = document.getElementById('menu-items-list');
            list.innerHTML = '';
            mockMenus[storeId].forEach(item => {
                list.innerHTML += `
                    <div class="menu-item-row">
                        <div class="menu-item-desc">
                            <h5>${item.name}</h5>
                            <p>${item.desc}</p>
                        </div>
                        <div class="menu-item-action">
                            <span class="menu-price">$${item.price.toFixed(2)}</span>
                            <button class="action-add-btn" onclick="addToCart('${item.id}', '${storeId}')">+</button>
                        </div>
                    </div>
                `;
            });

            // Update recently viewed tray
            if (recentlyViewed.indexOf(store.name) === -1) {
                recentlyViewed.push(store.name);
                if (recentlyViewed.length > 3) recentlyViewed.shift();
                updateRecentlyViewedTray();
            }
        }

        function updateRecentlyViewedTray() {
            const tray = document.getElementById('recently-viewed-tray');
            tray.innerHTML = recentlyViewed.map(name => `<span class="store-tag" style="position:relative; margin-right: 5px; background:var(--neon-blue);">${name}</span>`).join(' ');
        }

        function showCatalog() {
            document.getElementById('catalog-grid').style.display = 'grid';
            document.getElementById('restaurant-menu-details').style.display = 'none';
        }

        // ==========================================================================
        // 12. TELEMETRY LOG GENERATOR (OBSERVABILITY FEED)
        // ==========================================================================
        function addLog(service, message) {
            const terminal = document.getElementById('log-feed-terminal');
            const date = new Date().toISOString();
            const traceId = "tr_" + Math.random().toString(36).substr(2, 9);
            const spanId = "sp_" + Math.random().toString(36).substr(2, 9);
            
            const logEntry = `{"timestamp": "${date}", "service": "${service}", "trace_id": "${traceId}", "span_id": "${spanId}", "level": "INFO", "message": "${message}"}`;
            
            if (terminal) {
                terminal.innerHTML += `<div class="log-line">${logEntry}</div>`;
                terminal.scrollTop = terminal.scrollHeight;
            }
        }

        // Periodically output background log feeds to simulate event traffic
        setInterval(() => {
            const services = ["api-gateway", "user-service", "restaurant-service", "order-service", "payment-service", "delivery-service", "notification-service", "fraud-detection-service", "analytics-service"];
            const msgs = [
                "Incoming REST request routed via API Gateway.",
                "Redis Cache lookup resolved successfully.",
                "Kafka topic message consumed.",
                "OpenTelemetry trace exported to Jaeger backends.",
                "Prometheus scrape request processed.",
                "Outbox table scheduler polling completed.",
                "Geohash coordinate matches validated.",
                "SQL query timing profile: 8.5ms execution."
            ];
            const randomService = services[Math.floor(Math.random() * services.length)];
            const randomMsg = msgs[Math.floor(Math.random() * msgs.length)];
            addLog(randomService, randomMsg);
        }, 3000);

        // Initial setup
        renderCatalog(mockStores);
        addLog("api-gateway", "Service Discovery registration completed. All nodes online.");
    </script>
</body>
</html>

