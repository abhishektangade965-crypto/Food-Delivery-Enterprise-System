                        </div>
                        <select id="surge-toggle" onchange="toggleSurge(this.value)" style="background: rgba(0,0,0,0.3); color: white; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius-sm);">
                            <option value="1.0">Standard Pricing (1.0x)</option>
